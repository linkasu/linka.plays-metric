IMAGE_TAG=sha-tested-commit
CLICKHOUSE_VERSION=25.3.6.56-alpine
CADDY_VERSION=2.10.0-alpine
DATA_ROOT=/srv/linka-plays-metric-staging

CLICKHOUSE_ADMIN_USER=admin
CLICKHOUSE_ADMIN_PASSWORD=staging-secret-from-protected-environment
CLICKHOUSE_WRITER_PASSWORD=staging-writer-secret-from-protected-environment
CLICKHOUSE_PRIVACY_PASSWORD=staging-privacy-secret-from-protected-environment
CLICKHOUSE_DATALENS_PASSWORD=staging-datalens-secret-from-protected-environment
WRITER_HMAC_SECRET=staging-v1-secret-at-least-32-bytes
SERVICE_HMAC_ACTIVE_KEY_ID=staging-collector-1
SERVICE_HMAC_ACTIVE_SECRET=staging-v2-service-secret-at-least-32-bytes
INSTALLATION_HMAC_SECRET=staging-installation-secret-at-least-32-bytes
INSTALLATION_TOKEN_MAX_AGE=720h
DEPLOYMENT_ENVIRONMENT=staging
ALLOW_LEGACY_PRODUCT_TOKENS=true
PRODUCT_TOKEN_HMAC_ACTIVE_KEY_ID=staging-product-token-1
PRODUCT_TOKEN_HMAC_ACTIVE_SECRET=staging-product-token-secret-at-least-32-bytes
SUBJECT_KEY_HMAC_SECRET=staging-stable-subject-secret-at-least-32-bytes
PRODUCT_TOKEN_TTL=24h

RETENTION_V2_INGEST_BATCHES=
RETENTION_V2_COMMON=
RETENTION_V2_TECHNICAL=
RETENTION_V2_PLAYS=
RETENTION_V2_PRIVACY=
PRIVACY_WORKER_INTERVAL=30s
PRIVACY_WORKER_MAX_ATTEMPTS=10

ACME_EMAIL=ops@example.invalid
WRITER_DOMAIN=metric-writer.staging.example.invalid
DB_DOMAIN=metric-db.staging.example.invalid

SMTP_ADDR=smtp.staging.example.invalid:587
SMTP_FROM=metric-staging@example.invalid
SMTP_TO=ops@example.invalid
SMTP_USER=staging-monitor
SMTP_PASSWORD=staging-smtp-secret-from-protected-environment
