IMAGE_TAG=latest
CLICKHOUSE_VERSION=25.3.6.56-alpine
CADDY_VERSION=2.10.0-alpine
DATA_ROOT=/srv/linka-plays-metric

CLICKHOUSE_ADMIN_USER=admin
CLICKHOUSE_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
CLICKHOUSE_WRITER_PASSWORD=replace-with-a-long-random-writer-password
CLICKHOUSE_DATALENS_PASSWORD=replace-with-a-long-random-datalens-password
WRITER_HMAC_SECRET=replace-with-at-least-32-random-bytes

# Collector / standalone writer
INSTALLATION_HMAC_SECRET=replace-with-another-at-least-32-random-bytes
WRITER_URL=https://plays-metric-writer.nkolinka.ru
LISTEN_ADDR=:8080
CLICKHOUSE_ADDRS=clickhouse:9000
CLICKHOUSE_DATABASE=linka_metric
CLICKHOUSE_SECURE=false

ACME_EMAIL=ivan@aacidov.ru
WRITER_DOMAIN=plays-metric-writer.nkolinka.ru
DB_DOMAIN=plays-metric-db.nkolinka.ru

# cmd/disk-alert, keep SMTP_PASSWORD in the protected deployment environment
DISK_PATH=/host
DISK_THRESHOLD_PERCENT=80
DISK_ALERT_STATE_FILE=/var/lib/linka-metric/disk-alert.state
SMTP_ADDR=smtp.postbox.yandexcloud.net:587
SMTP_FROM=apps@nkolinka.ru
SMTP_TO=ivan@aacidov.ru
SMTP_USER=monitor
SMTP_PASSWORD=replace-with-smtp-password
