IMAGE_TAG=latest
CLICKHOUSE_VERSION=25.3.6.56-alpine
CADDY_VERSION=2.10.0-alpine
DATA_ROOT=/srv/linka-plays-metric

CLICKHOUSE_ADMIN_USER=admin
CLICKHOUSE_ADMIN_PASSWORD=replace-with-a-long-random-admin-password
CLICKHOUSE_WRITER_PASSWORD=replace-with-a-long-random-writer-password
CLICKHOUSE_PRIVACY_PASSWORD=replace-with-a-different-long-random-privacy-password
CLICKHOUSE_DATALENS_PASSWORD=replace-with-a-long-random-datalens-password
WRITER_HMAC_SECRET=replace-with-at-least-32-random-bytes
SERVICE_HMAC_ACTIVE_KEY_ID=collector-2026-07
SERVICE_HMAC_ACTIVE_SECRET=replace-with-a-different-at-least-32-byte-service-secret
# SERVICE_HMAC_PREVIOUS_KEY_ID=collector-previous
# SERVICE_HMAC_PREVIOUS_SECRET=replace-with-the-previous-service-secret-during-rotation

# Collector / standalone writer
INSTALLATION_HMAC_SECRET=replace-with-another-at-least-32-random-bytes
# INSTALLATION_HMAC_ACTIVE_KEY_ID=installation-2026-08
# INSTALLATION_HMAC_ACTIVE_SECRET=replace-with-new-at-least-32-byte-secret
# INSTALLATION_HMAC_PREVIOUS_KEY_ID=installation-2026-07
# INSTALLATION_HMAC_PREVIOUS_SECRET=replace-with-previous-secret-during-rotation
INSTALLATION_TOKEN_MAX_AGE=720h
DEPLOYMENT_ENVIRONMENT=production
IDENTITY_JWKS_URL=https://identity.example.test/.well-known/jwks.json
IDENTITY_TOKEN_ISSUER=https://identity.example.test
IDENTITY_TELEMETRY_AUDIENCE=linka-plays-metric
IDENTITY_TOKEN_MAX_LIFETIME=15m
# Staging only: ALLOW_LEGACY_PRODUCT_TOKENS=true plus PRODUCT_TOKEN_HMAC_* and SUBJECT_KEY_HMAC_SECRET.
WRITER_URL=https://plays-metric-writer.nkolinka.ru
LISTEN_ADDR=:8080
CLICKHOUSE_ADDRS=clickhouse:9000
CLICKHOUSE_DATABASE=linka_metric
CLICKHOUSE_SECURE=false

# Legal must approve these before activation. Empty means expires_at=NULL; SQL TTL is never enabled automatically.
RETENTION_V2_INGEST_BATCHES=
RETENTION_V2_COMMON=
RETENTION_V2_TECHNICAL=
RETENTION_V2_PLAYS=
RETENTION_V2_PRIVACY=
PRIVACY_WORKER_INTERVAL=30s
PRIVACY_WORKER_MAX_ATTEMPTS=10

ACME_EMAIL=ivan@aacidov.ru
WRITER_DOMAIN=plays-metric-writer.nkolinka.ru
DB_DOMAIN=plays-metric-db.nkolinka.ru

# cmd/disk-alert, keep SMTP_PASSWORD in the protected deployment environment
DISK_PATH=/host
DISK_THRESHOLD_PERCENT=80
DISK_ALERT_STATE_FILE=/var/lib/linka-metric/disk-alert.state
SMTP_ADDR=smtp.postbox.yandexcloud.net:587
SMTP_FROM=apps@nkolinka.ru
SMTP_TO=ivan@aacidov.ru
SMTP_USER=monitor
SMTP_PASSWORD=replace-with-smtp-password
